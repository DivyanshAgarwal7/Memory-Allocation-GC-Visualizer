# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.

# Server
PORT=4000
NODE_ENV=development

# Frontend origin allowed to call this API with credentials
ALLOWED_ORIGIN=http://localhost:4000

# SQLite database file (created automatically on first run)
DB_PATH=./data/memsim.db

# JWT secrets - generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Use a DIFFERENT value for each secret.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (jsonwebtoken "expiresIn" format)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# SMTP - used to send "forgot password" reset emails.
# Leave all of these blank for local development: the server will log the
# reset link to the console instead of sending a real email, so the
# password-reset flow is still fully testable with zero setup. Fill these
# in with real values (e.g. from SendGrid, Mailgun, or your own SMTP
# provider) before deploying somewhere people other than you will use it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
